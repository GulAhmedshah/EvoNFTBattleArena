Tx = await evoNFT.mint({ value: mintPrice });\n    const receipt = await mintTx.wait();\n    const mintEvent = receipt.events.find(e => e.event === 'Minted');\n    if (!mintEvent) {\n        console.error(\"Mint failed: Could not find Minted event.\");\n        return;\n    }\n    const tokenId = mintEvent.args.tokenId;\n    console.log(\`Successfully minted NFT with Token ID: \${tokenId.toString()}\`);\n\n    // 2. Stake the new NFT\n    console.log(\`Staking NFT #\${tokenId}...\`);\n    await (await evoNFT.approve(evoNFT.address, tokenId)).wait(); // Self-approval might be needed depending on implementation\n    const stakeTx = await evoNFT.stake([tokenId]);\n    await stakeTx.wait();\n    console.log(\"NFT staked successfully.\");\n\n    // 3. Check rewards (on local network)\n    if (network.name === 'hardhat' || network.name === 'localhost') {\n        console.log(\"Advancing time by 1 day to accrue rewards...\");\n        await ethers.provider.send(\"evm_increaseTime\", [86400]); // 1 day\n        await ethers.provider.send(\"evm_mine\");\n\n        const earned = await evoNFT.calculateRewards(signer.address, [tokenId]);\n        console.log(\`Earned rewards after 1 day: \${ethers.utils.formatUnits(earned, 18)} GTOK\`);\n    }\n}\n\ninteract().catch(console.error);\n    `;\n    fs.writeFileSync(path.join(__dirname, 'interact.js'), interactScriptContent.trim());\n    log(\"\\n[C] Generated 'scripts/interact.js' for example usage. Run: npx hardhat run scripts/interact.js --network \" + networkName);\n\n\n    const endTime = Date.now();\n    log(`\\nDeployment finished in ${(endTime - startTime) / 1000} seconds.`);\n\n  } catch (error) {\n    log(\"\\n--- DEPLOYMENT FAILED ---\");\n    console.error(error);\n    process.exit(1);\n  }\n}\n\nmain().then(() => process.exit(0));\n",
